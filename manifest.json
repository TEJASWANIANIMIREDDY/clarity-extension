{
  "manifest_version": 3,
  "name": "Clarity - Instant Assistant",
  "version": "1.0",
  "description": "Understand anything instantly",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}